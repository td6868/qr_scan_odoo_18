<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_packing_ticket">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <style>
                            @import url('https://fonts.googleapis.com/css2?family=Times+New+Roman:wght@400;700&amp;display=swap');

                            .ticket-page {
                                font-family: 'Times New Roman', Times, serif;
                                color: #000;
                                font-size: 19px;
                                line-height: 1.2;
                            }

                            .ticket-table {
                                width: 100%;
                                border-collapse: collapse;
                                border: 2px solid #000;
                                table-layout: fixed;
                            }

                            .ticket-table th,
                            .ticket-table td {
                                border: 1px solid #000;
                                padding: 5px 7px;
                                font-size: 21px;
                                vertical-align: middle;
                            }

                            .qr-cell {
                                width: 16%;
                                text-align: center;
                                vertical-align: middle !important;
                                padding: 4px !important;
                            }

                            .qr-img {
                                width: 112px;
                                height: 112px;
                            }

                            .ticket-title {
                                font-size: 19px;
                                font-weight: 700;
                                text-align: center;
                                text-transform: uppercase;
                                letter-spacing: 0.2px;
                                line-height: 1.15;
                                height: 40px;
                                padding: 4px 6px !important;
                                background-color: #fff;
                            }

                            .ticket-subtitle {
                                font-size: 20px;
                                font-weight: 400;
                                margin-top: 2px;
                                text-transform: uppercase;
                            }

                            .sender-cell {
                                text-align: center;
                                font-size: 25px !important;
                                font-weight: 700;
                                height: 40px;
                                padding: 4px 7px !important;
                            }

                            .receiver-head {
                                text-align: center;
                                font-size: 17px !important;
                                font-weight: 700;
                                height: 40px;
                            }

                            .info-label-cell {
                                width: 25%;
                                font-size: 18px !important;
                                font-weight: 700;
                                text-transform: uppercase;
                                vertical-align: top !important;
                                padding: 6px 7px !important;
                                line-height: 1.18;
                            }

                            .info-value-cell {
                                width: 75%;
                                font-size: 25px !important;
                                font-weight: 400;
                                vertical-align: top !important;
                                padding: 6px 7px !important;
                                line-height: 1.18;
                                word-break: break-word;
                            }
                        </style>

                        <div class="ticket-page">
                            <!-- ===== DATA LOGIC ===== -->
                            <t t-set="sale_user" t-value="doc.sale_id.user_id if doc.sale_id else doc.user_id"/>
                            <t t-set="sender_name" t-value="doc.sender_info or (sale_user.name if sale_user else '')"/>
                            <t t-set="sender_phone" t-value="sale_user.employee_id.work_phone or sale_user.mobile or '' if sale_user else ''"/>

                            <t t-set="wh" t-value="doc.picking_type_id.warehouse_id"/>
                            <t t-set="wh_partner" t-value="wh.partner_id if wh else False"/>
                            <t t-set="sender_company_name" t-value="wh.name if wh else 'Kho hàng'"/>
                            <t t-set="sender_address" t-value="''"/>
                            <t t-if="wh_partner">
                                <t t-set="parts" t-value="[wh_partner.street or '', wh_partner.street2 or '', wh_partner.city or '', wh_partner.state_id.name if wh_partner.state_id else '', wh_partner.country_id.name if wh_partner.country_id else '']"/>
                                <t t-set="sender_address" t-value="', '.join([p for p in parts if p])"/>
                            </t>


                            <!-- Thông tin gửi xe do sale nhập -->
                            <t t-set="park_info" t-value="doc.park_info or ''"/>

                            <!-- Recipient info: ưu tiên dữ liệu đã lưu từ wizard giao việc -->
                            <t t-set="recv_name" t-value="doc.recipient_name or '' "/>
                            <t t-set="recv_phone" t-value="doc.recipient_phone or '' "/>
                            <t t-set="recv_address" t-value="doc.recipient_address or '' "/>

                            <!-- Fallback to partner if no recipient info -->
                            <t t-if="not recv_name">
                                <t t-set="is_company" t-value="doc.partner_id.is_company"/>
                                <t t-set="recv_name" t-value="'' if is_company else doc.partner_id.name"/>
                                <t t-set="recv_phone" t-value="doc.partner_id.mobile or doc.partner_id.phone or ''"/>
                            </t>
                            <t t-if="not recv_address">
                                <t t-set="addr_parts" t-value="[doc.partner_id.street or '', doc.partner_id.street2 or '', doc.partner_id.city or '', doc.partner_id.state_id.name if doc.partner_id.state_id else '', doc.partner_id.country_id.name if doc.partner_id.country_id else '']"/>
                                <t t-set="recv_address" t-value="', '.join([p for p in addr_parts if p])"/>
                            </t>

                            <t t-set="shipping_cost_label" t-value="''"/>
                            <t t-if="doc.type_shipping_cost == '1'">
                                <t t-set="shipping_cost_label" t-value="'Khách hàng trả phí'"/>
                            </t>
                            <t t-elif="doc.type_shipping_cost == '2'">
                                <t t-set="shipping_cost_label" t-value="'Bao cước toàn bộ'"/>
                            </t>
                            <t t-elif="doc.type_shipping_cost == '3'">
                                <t t-set="shipping_cost_label" t-value="'Bao cước một phần'"/>
                            </t>

                            <!-- ===== TABLE LAYOUT: COMPACT THEO MẪU PHIẾU GỬI HÀNG ===== -->
                            <table class="ticket-table">
                                <tr>
                                    <td rowspan="2" class="qr-cell">
                                        <t t-if="doc.qr_code_image">
                                            <img t-att-src="image_data_uri(doc.qr_code_image)"
                                                 class="qr-img"
                                                 alt="QR Code"/>
                                        </t>
                                    </td>
                                    <td class="ticket-title">
                                        <div class="ticket-subtitle" t-if="doc.sale_id or doc.origin">
                                            <span t-esc="doc.sale_id.name or doc.origin"/>
                                            <span> - </span>
                                            <span t-esc="shipping_cost_label"/>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="sender-cell">
                                        NGƯỜI GỬI
                                        <t t-if="sender_name"> - <span t-esc="sender_name"/></t>
                                        <t t-if="sender_phone"> - <span t-esc="sender_phone"/></t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="info-label-cell">ĐỊA CHỈ</td>
                                    <td class="info-value-cell">
                                        <span t-esc="recv_address"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="info-label-cell">NGƯỜI NHẬN</td>
                                    <td class="info-value-cell">
                                        <strong t-if="recv_name" t-esc="recv_name"/>
                                        <t t-if="recv_name and recv_phone"> - </t>
                                        <strong t-if="recv_phone" t-esc="recv_phone"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="info-label-cell">THÔNG TIN GỬI XE</td>
                                    <td class="info-value-cell">
                                        <span style="font-size: 19px" t-esc="park_info"/>
                                    </td>
                                </tr>
                            </table>

                            <div style="page-break-after: always;"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
