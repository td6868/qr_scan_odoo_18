<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_packing_ticket">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="qr_report_page">
                        <div class="qr_a5_sheet qr_master_container">
                            <style>
                                /* AESTHETICS FONTS */
                                @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700;900&amp;display=swap');
                                
                                .qr_master_container {
                                    font-family: 'Roboto', Arial, sans-serif;
                                    color: #000000;
                                }

                                /* TABLE STYLING */
                                .qr_table {
                                    width: 100%;
                                    border-collapse: collapse;
                                    margin-top: 5px;
                                }
                                .qr_table th {
                                    background-color: #f8f9fa !important;
                                    border: 1px solid #000 !important;
                                    text-align: center;
                                    vertical-align: middle;
                                    padding: 6px;
                                    font-weight: bold;
                                    text-transform: uppercase;
                                    font-size: 14px;
                                }
                                .qr_table td {
                                    border: 1px solid #000 !important;
                                    padding: 6px;
                                    vertical-align: middle;
                                    font-size: 16px;
                                }
                                
                                .label_cell {
                                    width: 100px;
                                    font-weight: bold;
                                    background-color: #f8f9fa !important;
                                }

                                /* SPECIAL LABELS */
                                .info_label {
                                    font-weight: 700;
                                    color: #000;
                                    display: inline-block;
                                    margin-bottom: 5px;
                                    font-size: 16px;
                                    text-transform: uppercase;
                                }
                                .qr_container {
                                    text-align: center;
                                    margin-bottom: 15px;
                                }
                                .qr_img {
                                    width: 250px;
                                    height: 250px;
                                }
                                .doc_name {
                                    font-size: 22px;
                                    font-weight: bold;
                                    margin-top: 5px;
                                }

                                /* 1. HIỂN THỊ TRÊN MÀN HÌNH (ĐẸP SANG TRỌNG) */
                                @media screen {
                                    .qr_report_page {
                                        display: flex;
                                        justify-content: center;
                                    }
                                    .qr_a5_sheet {
                                        width: 260mm;
                                        min-height: 150mm;
                                        background: white;
                                        margin: 0 auto;
                                        padding: 10mm !important;
                                        box-sizing: border-box;
                                        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
                                    }
                                }
                                
                                .value_highlight {
                                    font-weight: bold;
                                    font-size: 18px;
                                }
                            </style>
                                                        
                            <table style="width: 100%; border: none; margin: 0; padding: 0; border-collapse: separate;">
                                <tr>
                                    <td style="width: 80%; vertical-align: top; font-size: 32px; line-height: 1.9; text-align: left; padding: 0; border: none;">
                                        <div>Người gửi: <span t-esc="doc.sender_info"/></div>
                                        <div>Địa chỉ: Hoàng Mai – Hà Nội</div>
                                        <div style="font-size: 34px; margin-top: 20px;">Người nhận: <strong><span style="text-transform: uppercase;" t-esc="doc.recipient_info"/></strong></div>
                                        <div style="font-size: 40px; font-weight: bold; margin-top: 20px;">Số điện thoại nhận: <span t-esc="doc.partner_id.phone or doc.partner_id.mobile or ''"/></div>
                                        <div style="font-size: 30px; font-style: italic; margin-top: 20px; line-height: 1.5;">Địa chỉ nhận hàng: <span t-esc="doc.partner_id.contact_address"/></div>
                                        <div style="font-weight: bold; font-size: 40px; margin-top: 30px;">Gửi xe <span t-esc="doc.demo_bus_company or ''"/></div>
                                    </td>
                                    <td style="width: 20%; vertical-align: top; text-align: right; padding: 0; padding-left: 20px; border: none;">
                                        <t t-if="doc.qr_code_image">
                                            <img t-att-src="image_data_uri(doc.qr_code_image)" style="width: 200px; height: 200px;" alt="QR Code"/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
