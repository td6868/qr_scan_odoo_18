<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="qr_scan_odoo_18.ShippingHistoryPopoverField">
        <div class="d-inline-flex align-items-center shipping-history-container" 
             t-on-click.stop="onClick"
             t-att-class="{ 'opacity-50': historyCount === 0 }">
            <button class="btn btn-link p-0 text-decoration-none"
                    t-att-disabled="historyCount === 0"
                    type="button">
                <i class="fa fa-history me-1"
                   t-att-class="{ 'text-primary': popover.isOpen, 'fa-spinner fa-spin': state.loading }"
                   title="Lịch sử gửi xe"/>
                <span class="badge badge-pill badge-info" t-if="historyCount > 0">
                    <t t-esc="historyCount"/>
                </span>
            </button>
        </div>
    </t>

    <t t-name="qr_scan_odoo_18.ShippingHistoryPopoverContent">
        <div class="shipping-history-popover-content" style="min-width: 600px; max-width: 800px;">
            <div class="p-2 border-bottom bg-light">
                <h6 class="mb-0">
                    <i class="fa fa-history me-2"/>
                    Lịch sử gửi xe
                </h6>
            </div>

            <t t-if="!props.data.length">
                <div class="text-muted text-center py-4">
                    <i class="fa fa-info-circle me-1"/>
                    Chưa có lịch sử gửi xe
                </div>
            </t>
            <t t-else="">
                <div class="shipping-history-table-wrap" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th class="small">Ngày giờ</th>
                                <th class="small">Thông tin gửi xe</th>
                                <th class="small">Đơn hàng</th>
                                <th class="small">Người nhận</th>
                                <th class="small text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="props.data" t-as="item" t-key="item.id">
                                <tr>
                                    <td class="small text-nowrap">
                                        <i class="fa fa-calendar-o me-1 text-muted"/>
                                        <t t-esc="item.date"/>
                                    </td>
                                    <td class="small" style="white-space: pre-line; min-width: 220px;">
                                        <t t-esc="item.park_info || '—'"/>
                                    </td>
                                    <td class="small">
                                        <span class="badge text-muted">
                                            <t t-esc="item.sale_order || '—'"/>
                                        </span>
                                    </td>
                                    <td class="small">
                                        <t t-if="item.recipient_name">
                                            <div><t t-esc="item.recipient_name"/></div>
                                            <div class="text-muted" t-if="item.recipient_phone">
                                                <i class="fa fa-phone me-1"/>
                                                <t t-esc="item.recipient_phone"/>
                                            </div>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-primary"
                                                t-att-disabled="state.applyingId === item.id"
                                                t-on-click.stop="() => this.applyHistory(item)">
                                            <t t-if="state.applyingId === item.id">
                                                <i class="fa fa-spinner fa-spin me-1"/>
                                                Đang áp dụng...
                                            </t>
                                            <t t-else="">
                                                <i class="fa fa-check me-1"/>
                                                Chọn
                                            </t>
                                        </button>
                                    </td>
                                </tr>
                                <tr t-if="item.note" class="border-0">
                                    <td colspan="5" class="small text-muted ps-4 pt-0">
                                        <i class="fa fa-sticky-note-o me-1"/>
                                        <em><t t-esc="item.note"/></em>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </div>
    </t>

</templates>
