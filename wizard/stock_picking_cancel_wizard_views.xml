<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_picking_cancel_wizard_form" model="ir.ui.view">
        <field name="name">stock.picking.cancel.wizard.form</field>
        <field name="model">stock.picking.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Lý do từ chối giao việc">
                <group>
                    <field name="picking_id" invisible="1"/>
                    <field name="reason" placeholder="Ví dụ: Thiếu sản phẩm để soạn hàng, Sai phương thức vận chuyển, v.v..." required="1"/>
                </group>
                <footer>
                    <button string="Xác nhận từ chối" name="action_confirm_cancel" type="object" class="btn-danger" data-hotkey="q"/>
                    <button string="Hủy bỏ" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_picking_cancel_wizard" model="ir.actions.act_window">
        <field name="name">Từ chối giao việc</field>
        <field name="res_model">stock.picking.cancel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
