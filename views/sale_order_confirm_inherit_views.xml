<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kế thừa view wizard xác nhận đơn hàng -->
    <record id="view_sale_order_confirm_inherit_qr" model="ir.ui.view">
        <field name="name">Xác nhận đơn hàng - Thông tin gửi xe</field>
        <field name="model">sale.order.confirm.kk</field>
        <field name="inherit_id" ref="khoakim_18.view_sale_order_confirm"/>
        <field name="arch" type="xml">
            <field name="shipping_method" position="after">
                <field name="shipping_method_name" invisible="1"/>
                <field name="park_info"
                       invisible="shipping_method_name != 'Xe tải/ Xe bus'"
                       placeholder="Nhập Thông tin gửi xe"/>
            </field>
        </field>
    </record>
</odoo>
