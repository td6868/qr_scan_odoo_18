<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_shipping_carrier" model="ir.ui.view">
        <field name="name">stock.picking.form.shipping.carrier</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Thông tin gửi xe" name="shipping_carrier_info" 
                      invisible="park_info == False and ship_inf_state == 'none'">
                    <group>
                        <group string="Thông tin gửi xe">
                            <field name="park_info" readonly="1"/>
                            <field name="ship_inf_state" readonly="1" widget="badge" 
                                   decoration-muted="ship_inf_state == 'none'" 
                                   decoration-warning="ship_inf_state == 'not_received'" 
                                   decoration-info="ship_inf_state == 'received'" 
                                   decoration-success="ship_inf_state == 'completed'"/>
                        </group>
                        <group string="Thông tin gửi xe">
                            <field name="shipping_confirmed_by" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Thông tin xe">
                            <field name="shipping_driver_phone" readonly="1"/>
                            <field name="shipping_vehicle_number" readonly="1"/>
                            <field name="shipping_tracking_number" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
