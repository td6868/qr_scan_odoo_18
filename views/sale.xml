<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_qr" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.qr</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_invoice']" position="before">
                <button name="action_view_image_proof" type="object" class="btn oe_stat_button"
                        icon="fa-image" invisible="state == 'draft'">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Ảnh minh chứng</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='shipping_method']" position="after">
                <field name="demo_bus_company" invisible="demo_bus_company == False"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='qty_available']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='name']" position="after">
                <field name="is_description_mismatch" column_invisible="True"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='name']" position="attributes">
                <attribute name="decoration-danger">is_description_mismatch</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='qty_available']" position="after">
                <field name="available_to_use" string="TKKD" readonly="1" optional="show"
                       column_invisible="parent.state != 'draft'"/>
                <field name="incoming_qty" string="SL sắp về" readonly="1" optional="show"
                       column_invisible="parent.state != 'draft'" widget="incoming_popover"/>
                <field name="order_stock_move_qty" string="Tồn đơn hàng" readonly="1" optional="show"
                       column_invisible="parent.state not in ('sale', 'done')"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']" position="after">
                <field name="latest_stock_increase_date" string="Ngày tăng TK" readonly="1" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>