<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_qr" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.qr</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_invoice']" position="before">
                <button name="action_view_image_proof" type="object" class="btn oe_stat_button"
                        icon="fa-image" invisible="state == 'draft'">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Ảnh minh chứng</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='shipping_method']" position="after">
                <field name="demo_bus_company" invisible="demo_bus_company == False"/>
            </xpath>
        </field>
    </record>
</odoo>