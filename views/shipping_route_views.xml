<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========== SHIPPING ROUTE VIEWS ========== -->
    
    <!-- Tree View -->
    <record id="view_shipping_route_tree" model="ir.ui.view">
        <field name="name">shipping.route.tree</field>
        <field name="model">shipping.route</field>
        <field name="arch" type="xml">
            <list string="Tuyến đường">
                <field name="name"/>
                <field name="origin_city"/>
                <field name="destination_city"/>
                <field name="estimated_days"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_shipping_route_form" model="ir.ui.view">
        <field name="name">shipping.route.form</field>
        <field name="model">shipping.route</field>
        <field name="arch" type="xml">
            <form string="Tuyến đường">
                <sheet>
                    <group>
                        <group>
                            <field name="origin_city" placeholder="VD: Hà Nội"/>
                            <field name="destination_city" placeholder="VD: Đà Nẵng"/>
                        </group>
                        <group>
                            <field name="estimated_days"/>
                        </group>
                    </group>
                    <group string="Các nhà xe phục vụ">
                        <field name="company_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Ghi chú">
                        <field name="note" placeholder="Ghi chú về tuyến đường..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_shipping_route" model="ir.actions.act_window">
        <field name="name">Tuyến đường</field>
        <field name="res_model">shipping.route</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo tuyến đường mới
            </p>
            <p>
                Quản lý các tuyến đường vận chuyển.
            </p>
        </field>
    </record>

</odoo>
