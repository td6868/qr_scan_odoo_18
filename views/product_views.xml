<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Product Template Kanban View - Replace "On Hand" bằng "Tồn khả dụng" -->
    <record id="view_product_template_kanban_inherit_qr" model="ir.ui.view">
        <field name="name">product.template.kanban.inherit.qr</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_kanban_stock_view"/>
        <field name="arch" type="xml">
            <!-- Replace dòng "On hand: qty_available" bằng "Hiện có: available_to_use_tmpl" -->
            <xpath expr="//div[field[@name='qty_available']]" position="replace">
                <div groups="stock.group_stock_user" t-if="record.show_on_hand_qty_status_button.raw_value">
                    Hiện có: <field name="available_to_use_tmpl"/> <field name="uom_id" groups="uom.group_uom"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
